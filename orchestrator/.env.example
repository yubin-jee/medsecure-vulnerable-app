# SecureFlow - Automated Security Remediation Pipeline
# Orchestrator for CodeQL → Devin → Slack/Dashboard

GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=medsecure-vulnerable-app

DEVIN_API_KEY=your_devin_api_key_here
DEVIN_API_BASE=https://api.devin.ai/v1

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_SECURITY_CHANNEL=#security-alerts
SLACK_ENGINEERING_CHANNEL=#engineering

# Rate limiting
MAX_CONCURRENT_SESSIONS=3
POLL_INTERVAL_SECONDS=30

# Dashboard
DASHBOARD_PORT=8080
